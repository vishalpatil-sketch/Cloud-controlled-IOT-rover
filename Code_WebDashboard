<!DOCTYPE html>
<html>
<head>
<title>Cloud Car Control</title>
<script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>

<style>
body{
background:#111;
color:white;
text-align:center;
font-family:Arial;
}

h1{
margin-top:20px;
}

button{
width:110px;
height:60px;
margin:10px;
font-size:18px;
border:none;
border-radius:10px;
cursor:pointer;
}

.forward{background:#2ecc71;}
.reverse{background:#e74c3c;}
.left{background:#f39c12;}
.right{background:#3498db;}
.stop{background:white;color:black;}

.slider{
width:250px;
}

#status{
margin-top:15px;
}

#speedVal{
font-size:20px;
color:#0f0;
}
</style>

</head>

<body>

<h1>🚗 Cloud Car Control</h1>

<!-- Buttons (for mobile) -->
<button class="forward" onclick="send('F')">Forward</button><br>

<button class="left" onclick="send('L')">Left</button>
<button class="stop" onclick="send('S')">Stop</button>
<button class="right" onclick="send('R')">Right</button><br>

<button class="reverse" onclick="send('B')">Reverse</button>

<h3>Speed: <span id="speedVal">150</span></h3>
<input type="range" min="0" max="255" value="150" class="slider"
oninput="setSpeed(this.value)">

<p>Keyboard: W A S D | Space = Stop</p>

<p id="status">Connecting...</p>

<script>

// ===== MQTT CONNECT =====
const client = mqtt.connect(
'---------------',
{
username:"your username",
password:"password"
} //replace with your credentials
);

client.on('connect', ()=>{
document.getElementById("status").innerHTML="🟢 Connected";
});

// ===== SEND FUNCTIONS =====
function send(cmd){
client.publish("car/control",cmd);
}

function setSpeed(val){
document.getElementById("speedVal").innerText = val;
client.publish("car/control","V"+val);
}

// ===== WASD CONTROL (SMART) =====
let activeKey = null;

document.addEventListener("keydown",(e)=>{

let key = e.key.toLowerCase();

// prevent repeat spam
if(activeKey === key) return;

activeKey = key;

if(key==="w") send("F");
if(key==="s") send("B");
if(key==="a") send("L");
if(key==="d") send("R");
if(key===" ") send("S");

});

document.addEventListener("keyup",(e)=>{

let key = e.key.toLowerCase();

if(key === activeKey){
activeKey = null;
send("S");
}

});

</script>

</body>
</html>
